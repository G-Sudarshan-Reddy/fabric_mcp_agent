# Silver layer - cleansing and validation
# Generated by FabricOps Agent
# Table: {{ table_name }}

from pyspark.sql.functions import col, trim, to_date

workspace_id = spark.conf.get("trident.workspace.id")
lakehouse_id = spark.conf.get("trident.lakehouse.id", "{{ lakehouse_id }}")
source_path = f"abfss://{workspace_id}@onelake.dfs.fabric.microsoft.com/{lakehouse_id}/Files/{{ source_file }}"
source_table = "{{ bronze_table_name }}"
target_table = "{{ silver_table_name }}"
key_columns = {{ key_columns | tojson }}

print(f"Silver: Reading from {source_table}")
df = spark.read.format("delta").table(source_table)

print(f"Silver: Row count before cleansing: {df.count()}")

df = df.dropDuplicates()
df = df.dropna(subset=key_columns)

{% for col_name, col_type in column_casts.items() %}
df = df.withColumn("{{ col_name }}", col("{{ col_name }}").cast("{{ col_type }}"))
{% endfor %}

row_count = df.count()
assert row_count > 0, f"Silver FAILED: zero rows after cleansing from {source_table}"

df.write.format("delta").mode("overwrite").saveAsTable(target_table)
print(f"Silver COMPLETE: {row_count} rows written to {target_table}")
