# Bronze layer - raw ingestion
# Generated by FabricOps Agent
# Table: {{ table_name }} | Source: {{ source_file }}

from pyspark.sql.functions import current_timestamp, lit
import json

workspace_id = spark.conf.get("trident.workspace.id")
lakehouse_id = spark.conf.get("trident.lakehouse.id", "{{ lakehouse_id }}")
source_path = f"abfss://{workspace_id}@onelake.dfs.fabric.microsoft.com/{lakehouse_id}/Files/{{ source_file }}"
target_table = "{{ bronze_table_name }}"

print(f"Bronze: Reading from {source_path}")
df = spark.read.option("header", "true").option("inferSchema", "true").csv(source_path)

print(f"Bronze: Source schema:")
df.printSchema()

df = df.withColumn("_ingested_at", current_timestamp())
df = df.withColumn("_source_file", lit("{{ source_file }}"))

row_count = df.count()
assert row_count > 0, f"Bronze FAILED: zero rows read from {source_path}"

df.write.format("delta").mode("overwrite").saveAsTable(target_table)
print(f"Bronze COMPLETE: {row_count} rows written to {target_table}")
