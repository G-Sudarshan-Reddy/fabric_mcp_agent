# Gold layer - aggregation and serving
# Generated by FabricOps Agent
# Table: {{ table_name }}

from pyspark.sql.functions import sum as _sum, count, avg, col, round as _round

workspace_id = spark.conf.get("trident.workspace.id")
lakehouse_id = spark.conf.get("trident.lakehouse.id", "{{ lakehouse_id }}")
source_path = f"abfss://{workspace_id}@onelake.dfs.fabric.microsoft.com/{lakehouse_id}/Files/{{ source_file }}"
source_table = "{{ silver_table_name }}"
target_table = "{{ gold_table_name }}"
group_by_cols = {{ group_by_columns | tojson }}
agg_col = "{{ aggregation_column }}"

print(f"Gold: Reading from {source_table}")
df = spark.read.format("delta").table(source_table)

gold_df = df.groupBy(group_by_cols).agg(
	count("*").alias("record_count"),
	_round(_sum(col(agg_col)), 2).alias(f"total_{agg_col}"),
	_round(avg(col(agg_col)), 2).alias(f"avg_{agg_col}")
).orderBy(col("record_count").desc())

row_count = gold_df.count()
assert row_count > 0, f"Gold FAILED: zero rows after aggregation from {source_table}"

gold_df.write.format("delta").mode("overwrite").saveAsTable(target_table)
print(f"Gold COMPLETE: {row_count} rows written to {target_table}")
print("Gold preview:")
gold_df.show(10, truncate=False)
