FABRIC_WORKSPACE_ID=your-workspace-id-here
# Find this by opening control_lh in Fabric portal and copying the item ID from the URL,
# or use the workspace inventory report and copy the control_lh item ID.
FABRIC_LAKEHOUSE_ID=your-control-lh-item-id-here
FABRIC_TENANT_ID=your-tenant-id-here
# Stage 3 — notebook IDs (pre-filled with current values)
BRONZE_NOTEBOOK_ID=d2c11d0d-329f-46de-9247-2c633764a026
SILVER_NOTEBOOK_ID=6b845e96-75e2-4e32-8a30-7a81f81bcf23
GOLD_NOTEBOOK_ID=c8a8e8a7-a50f-48d5-b42f-9a5f6b314267
# Optional — leave empty if no Teams webhook
TEAMS_WEBHOOK_URL=
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint-here
AZURE_OPENAI_KEY=your-azure-openai-key-here

python -m fabricops_mcp.server
.venv/Scripts/python.exe -c "from fabricops_mcp.auth import get_token; import asyncio; t = asyncio.run(get_token()); print('SUCCESS - token starts with:', t[:20])"